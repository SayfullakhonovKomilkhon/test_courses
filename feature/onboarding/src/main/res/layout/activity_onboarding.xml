<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".presentation.OnboardingActivity">

    <!-- Top title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="100dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="Тысячи курсов\nв одном месте"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineHeight="36sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Staggered tag cloud of chips -->
    <LinearLayout
        android:id="@+id/llChipsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 -->
        <HorizontalScrollView
            android:id="@+id/hsvRow1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginVertical="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1С Администрирование"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RabbitMQ"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_green"
                    android:rotation="-10"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Трафик"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 2 -->
        <HorizontalScrollView
            android:id="@+id/hsvRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginVertical="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:translationX="-50dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Контент маркетинг"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="B2B маркетинг"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google Аналитика"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 3 -->
        <HorizontalScrollView
            android:id="@+id/hsvRow3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginVertical="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:translationX="-55dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UX исследователь"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Веб-аналитика"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Big Data"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_green"
                    android:rotation="8"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 4 -->
        <HorizontalScrollView
            android:id="@+id/hsvRow4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginVertical="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:translationX="-45dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Дизайн"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Веб-дизайн"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cinema 4D"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Промпт инжиниринг"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Row 5 -->
        <HorizontalScrollView
            android:id="@+id/hsvRow5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_marginVertical="6dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:translationX="-105dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Web-разработка"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Three.js"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_green"
                    android:rotation="-12"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Парсинг"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Python-разработка"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="14dp"
                    android:background="@drawable/bg_badge_grey"
                    android:singleLine="true"
                    android:ellipsize="none" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Bottom Action Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_rounded_button"
        android:text="Продолжить"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
